generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(uuid())
  email              String              @unique
  phone              String?             @unique
  first_name         String?
  last_name          String?
  userName           String?             @unique
  password           String
  district           String?
  upazila            String?
  avatarUrl          String?
  bio                String?
  dateOfBirth        DateTime?
  latitude           Float?
  longitude          Float?
  type               String?             @default("user")
  status             Int?                @default(1)
  isVerified         Boolean             @default(false)
  firebaseToken      String?             @unique
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  sentMessages       Message[]           @relation("SentMessages")
  roomMemberships    Room[]
  verificationTokens verificationToken[]
  comments           comment[]

  @@map("users")
}


model districts {
  id        Int    @id @default(autoincrement())
  name      String @unique
  latitude  Float
  longitude Float

  @@map("districts")
}



model comment {
  id         String   @id @default(uuid())
  content    String
  authorId   String
  postId     String
  // --- New Fields for Replies ---
  parentId   String?   // If null, it's a top-level comment
  parent     comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies    comment[] @relation("CommentReplies")
  hasReplies Boolean  @default(false)
  author     User     @relation(fields: [authorId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("comments")
}

model Room {
  id        String    @id @default(uuid())
  roomKey   String?   @unique
  type      RoomType  @default(DIRECT)
  name      String?
  members   User[]
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("rooms")
}

model Message {
  id        String    @id @default(uuid())
  content   String
  senderId  String
  roomId    String
  readAt    DateTime?
  createdAt DateTime  @default(now())
  sender    User      @relation("SentMessages", fields: [senderId], references: [id])
  room      Room      @relation(fields: [roomId], references: [id])

  @@map("messages")
}

enum RoomType {
  DIRECT
  GROUP
}

model verificationToken {
  id        String   @id @default(uuid())
  userId    String?
  email     String?  @unique
  token     String
  expiresAt DateTime
  user      User?    @relation(fields: [userId], references: [id])

  @@map("verification_tokens")
}
